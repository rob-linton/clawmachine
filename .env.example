# ClaudeCodeClaw environment configuration
# Copy to .env and adjust values

# Redis
CLAW_REDIS_URL=redis://127.0.0.1:6379/9
CLAW_REDIS_DB=9

# API server
CLAW_API_PORT=8080
CLAW_STATIC_DIR=flutter_ui/build/web

# Worker
CLAW_WORKER_CONCURRENCY=1
CLAW_WORKER_REPLICAS=1

# Scheduler
CLAW_CRON_INTERVAL=30

# Claude Code auth: uses OAuth (no API key needed)
# Workers mount ~/.claude/ from the host for OAuth tokens.

# Logging
RUST_LOG=info
