# ClaudeCodeClaw environment configuration
# Copy to .env and adjust values

# === Deployment ===
# IP address or hostname of the server (used by Caddy for TLS cert)
CLAW_HOST_IP=192.168.1.50

# === Authentication ===
# Admin user bootstrapped on first startup (when no users exist)
CLAW_ADMIN_USER=admin
CLAW_ADMIN_PASSWORD=changeme

# Bearer token for CLI/API automation (optional, acts as admin)
# CLAW_API_TOKEN=your-secret-token

# === Redis ===
CLAW_REDIS_PASSWORD=changeme-redis
CLAW_REDIS_DB=0

# === API server ===
CLAW_API_PORT=8080
CLAW_STATIC_DIR=flutter_ui/build/web

# CORS origin (set to match your access URL; omit for permissive dev mode)
# CLAW_CORS_ORIGIN=https://192.168.1.50

# === Worker ===
CLAW_WORKER_CONCURRENCY=1
CLAW_WORKER_REPLICAS=1

# === Docker Isolation ===
# Host path for workspace data (bind mount shared between API and worker)
# Must be writable by the current user. Default: ~/.claw-data
# CLAW_DATA_DIR=~/.claw-data

# Execution backend: "docker" (sandboxed, recommended) or "local" (direct subprocess)
CLAW_EXECUTION_BACKEND=docker

# === Claude Code auth ===
# Auth directory mounted into worker and sandbox containers.
# On Linux, Claude stores auth tokens in ~/.claude/
CLAUDE_HOME=~/.claude
CLAUDE_JSON=~/.claude.json

# === Scheduler ===
CLAW_CRON_INTERVAL=30

# === Logging ===
RUST_LOG=info
